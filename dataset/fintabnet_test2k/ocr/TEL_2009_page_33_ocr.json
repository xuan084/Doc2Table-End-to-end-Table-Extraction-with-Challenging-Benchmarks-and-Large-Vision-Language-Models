necessary.", "bbox": [185.5, 1026.9, 595.5, 1043.5]}, {"text": "(2)", "bbox": [143.8, 1058.7, 164.9, 1075.4]}, {"text": "Represents the change in net sales resulting from volume and price changes, before consideration of acquisitions,", "bbox": [185.5, 1058.7, 1013.1, 1075.4]}, {"text": "divestitures, and the impact of changes in foreign currency exchange rates.", "bbox": [185.5, 1079.6, 728.9, 1096.2]}, {"text": "(3)", "bbox": [143.8, 1111.5, 164.9, 1128.1]}, {"text": "Represents the percentage change in net sales resulting from changes in foreign currency exchange rates.", "bbox": [185.5, 1111.5, 952.5, 1128.1]}, {"text": "Fiscal 2009 Compared to Fiscal 2008", "bbox": [185.5, 1156.5, 509.2, 1177.3]}, {"text": "Network Solutions’ net sales decreased $443 million, or 20.5%, to $1,719 million in fiscal 2009", "bbox": [185.5, 1192.9, 1045.8, 1213.8]}, {"text": "from $2,162 million in fiscal 2008. The weakening of certain foreign currencies negatively affected net", "bbox": [143.8, 1217.9, 1073.5, 1238.8]}, {"text": "sales by $173 million, or 8.0%, in fiscal 2009 over fiscal 2008. Organic net sales decreased $270 million,", "bbox": [143.8, 1243.0, 1086.9, 1263.8]}, {"text": "or 12.5%, in fiscal 2009 over fiscal 2008.", "bbox": [143.8, 1268.0, 511.5, 1288.8]}, {"text": "Our organic net sales decreased 9.0% in the energy industry end market in fiscal 2009 as", "bbox": [185.5, 1304.0, 998.8, 1324.9]}, {"text": "compared to fiscal 2008 primarily due to declines in Europe. Sales in Europe were negatively impacted", "bbox": [143.8, 1329.0, 1085.2, 1349.9]}, {"text": "by slower investment levels by utilities and reduced customer inventory levels. In the service providers", "bbox": [143.8, 1354.0, 1074.4, 1374.9]}, {"text": "market, our organic net sales decrease of 12.3% in fiscal 2009 as compared to fiscal 2008 was largely", "bbox": [143.8, 1379.0, 1064.5, 1399.9]}, {"text": "29", "bbox": [1073.4, 1465.9, 1094.2, 1486.8]}]}