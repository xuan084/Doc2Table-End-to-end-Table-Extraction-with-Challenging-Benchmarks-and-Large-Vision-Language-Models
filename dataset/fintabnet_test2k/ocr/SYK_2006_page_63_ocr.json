9.6, 927.4]}, {"text": "$ 369.5", "bbox": [1002.1, 907.6, 1068.8, 927.4]}, {"text": "$ 333.6", "bbox": [1106.3, 907.6, 1177.5, 927.4]}, {"text": "Net operating loss carryforwards totaling approximately $47.6 million at December 31, 2006 are available to reduce future taxable", "bbox": [175.0, 965.9, 1175.0, 985.7]}, {"text": "earnings of certain domestic and foreign subsidiaries.", "bbox": [150.0, 995.1, 570.2, 1014.9]}, {"text": "Deferred income tax assets and liabilities are included in the consolidated balance sheets as follows (in millions):", "bbox": [175.0, 1024.2, 1056.2, 1044.0]}, {"text": "December 31", "bbox": [1062.2, 1074.8, 1133.7, 1088.3]}, {"text": "2006", "bbox": [1033.6, 1099.2, 1075.4, 1119.0]}, {"text": "2005", "bbox": [1137.8, 1099.2, 1179.6, 1119.0]}, {"text": "Current assets—Deferred income taxes", "bbox": [150.0, 1128.4, 457.7, 1148.2]}, {"text": "$ 417.2", "bbox": [1002.1, 1128.4, 1068.8, 1148.2]}, {"text": "$ 383.1", "bbox": [1106.3, 1128.4, 1177.5, 1148.2]}, {"text": "Noncurrent assets—Deferred income taxes", "bbox": [150.0, 1157.6, 488.3, 1177.4]}, {"text": "118.6", "bbox": [1026.0, 1157.6, 1068.7, 1177.4]}, {"text": "91.1", "bbox": [1139.6, 1157.6, 1177.4, 1177.4]}, {"text": "Current liabilities—Accrued expenses and other liabilities", "bbox": [150.0, 1186.7, 604.0, 1206.5]}, {"text": "(38.1)", "bbox": [1027.6, 1186.7, 1075.5, 1206.5]}, {"text": "(35.8)", "bbox": [1132.3, 1186.7, 1180.2, 1206.5]}, {"text": "Noncurrent liabilities—Other liabilities", "bbox": [150.0, 1215.9, 461.7, 1235.7]}, {"text": "(128.2)", "bbox": [1018.1, 1215.9, 1075.5, 1235.7]}, {"text": "(104.8)", "bbox": [1122.8, 1215.9, 1180.2, 1235.7]}, {"text": "Total net deferred income tax assets", "bbox": [150.0, 1245.1, 429.6, 1264.9]}, {"text": "$ 369.5", "bbox": [1002.1, 1245.1, 1068.8, 1264.9]}, {"text": "$ 333.6", "bbox": [1106.3, 1245.1, 1177.5, 1264.9]}, {"text": "At December 31, 2006, tax authorities in several tax jurisdictions both inside and outside the United States were conducting rou-", "bbox": [175.0, 1303.4, 1175.0, 1323.2]}, {"text": "tine audits of the Company’s income tax returns ﬁled in prior years. These audits are generally designed to determine if individual", "bbox": [150.0, 1332.6, 1175.0, 1352.4]}, {"text": "tax authorities are in agreement with the Company’s interpretations of complex income tax regulations regarding the allocation of", "bbox": [150.0, 1361.7, 1175.0, 1381.5]}, {"text": "income to the various tax jurisdictions. During 2006, the Company did not reach resolution on any signiﬁcant outstanding tax audit", "bbox": [150.0, 1390.9, 1175.0, 1410.7]}, {"text": "and, therefore, increased its income tax accruals by $19.7 million for the Company’s best estimate of the probable resolution of these", "bbox": [150.0, 1420.1, 1175.0, 1439.9]}, {"text": "tax positions.", "bbox": [150.0, 1449.2, 255.5, 1469.0]}]}