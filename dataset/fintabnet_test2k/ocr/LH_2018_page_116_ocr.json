4, 1072.5]}, {"text": "—", "bbox": [1128.4, 1049.4, 1149.3, 1072.5]}, {"text": "GILTI", "bbox": [110.4, 1072.3, 163.8, 1095.4]}, {"text": "1.0", "bbox": [877.4, 1072.3, 903.4, 1095.4]}, {"text": "—", "bbox": [998.5, 1072.3, 1019.4, 1095.4]}, {"text": "—", "bbox": [1128.4, 1072.3, 1149.3, 1095.4]}, {"text": "Other", "bbox": [110.4, 1095.3, 157.9, 1118.3]}, {"text": "0.5", "bbox": [877.4, 1095.3, 903.4, 1118.3]}, {"text": "0.9", "bbox": [993.3, 1095.3, 1019.4, 1118.3]}, {"text": "0.2", "bbox": [1123.2, 1095.3, 1149.3, 1118.3]}, {"text": "Effective rate", "bbox": [110.4, 1118.2, 222.8, 1141.2]}, {"text": "30.3%", "bbox": [867.0, 1118.2, 920.8, 1141.2]}, {"text": "(14.4)%", "bbox": [975.9, 1118.2, 1043.7, 1141.2]}, {"text": "33.6%", "bbox": [1112.8, 1118.2, 1166.6, 1141.2]}, {"text": "In December 2017, the U.S. enacted the TCJA, which made widespread changes to the Internal Revenue Code. The TCJA,", "bbox": [141.7, 1151.8, 1176.1, 1174.8]}, {"text": "among other things, reduced the U.S. federal corporate tax rate from 35% to 21% beginning January 1, 2018, requires companies", "bbox": [104.2, 1176.8, 1176.1, 1199.8]}, {"text": "to pay a repatriation tax on earnings of certain foreign subsidiaries that were previously not subject to U.S. tax, and created new", "bbox": [104.2, 1201.8, 1176.0, 1224.8]}, {"text": "income taxes on certain foreign sourced earnings. Also on December 22, 2017, the U.S. Securities and Exchange Commission", "bbox": [104.2, 1226.8, 1176.1, 1249.8]}, {"text": "(SEC) issued Staff Accounting Bulletin No. 118 (SAB 118), which provided companies with additional guidance on how to account", "bbox": [104.2, 1251.8, 1176.1, 1274.8]}, {"text": "for the TCJA in its financial statements, allowing companies utilize a one year measurement period. At December 31, 2017, the", "bbox": [104.2, 1276.8, 1176.0, 1299.8]}, {"text": "Company had not completed the accounting for the tax effects of enactment of the TCJA; however, as described below, a reasonable", "bbox": [104.2, 1301.8, 1176.0, 1324.8]}, {"text": "estimate on the re-measurement of the Company's existing deferred tax balances, the deferred tax revaluation for unremitted", "bbox": [104.2, 1326.8, 1176.1, 1349.8]}, {"text": "foreign earnings, and the one-time repatriation tax was  made. For these items, in accordance with SAB 118, a provisional net", "bbox": [104.2, 1351.8, 1176.0, 1374.8]}, {"text": "benefit was recognized, totaling $519.0, which is included as a component of income tax expense from continuing operations.", "bbox": [104.2, 1376.8, 1176.0, 1399.8]}, {"text": "The Company continued to assess the impact of TCJA throughout the 2018 calendar year and finalized the SAB 118 provisional", "bbox": [104.2, 1401.8, 1176.1, 1424.8]}, {"text": "estimate in the fourth quarter of 2018. For 2018, the Company recorded a total tax expense of $45.0, $14.8 related to the repatriation", "bbox": [104.2, 1426.8, 1176.1, 1449.8]}, {"text": "tax and $30.1 for the remeasurement of deferred taxes. Overall a net benefit of $474.0 was recorded for TCJA tax provisions", "bbox": [104.2, 1451.8, 1176.1, 1474.8]}, {"text": "effective as of the end of 2018. As additional regulations or guidance in relation to the TCJA are issued, the Company will analyze", "bbox": [104.2, 1476.8, 1176.1, 1499.8]}, {"text": "and record the necessary impacts during the quarter in which this occurs.", "bbox": [104.2, 1501.8, 711.6, 1524.8]}]}