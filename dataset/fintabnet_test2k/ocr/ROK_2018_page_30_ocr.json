3, 617.1]}, {"text": "(64.9)", "bbox": [682.6, 597.0, 724.7, 617.1]}, {"text": "3,355.1", "bbox": [765.3, 597.1, 820.1, 617.1]}, {"text": "3,244.3", "bbox": [871.6, 597.1, 926.4, 617.1]}, {"text": "—", "bbox": [1018.1, 597.1, 1032.8, 617.1]}, {"text": "3,244.3", "bbox": [1090.2, 597.1, 1145.0, 617.1]}, {"text": "TOTAL COMPANY SALES", "bbox": [94.5, 626.7, 282.2, 647.3]}, {"text": "$ 6,311.3 $", "bbox": [325.8, 626.7, 424.2, 647.3]}, {"text": "15.1 $", "bbox": [472.8, 626.7, 530.6, 647.3]}, {"text": "6,326.4 $", "bbox": [555.0, 626.7, 631.0, 647.3]}, {"text": "(87.4) $ 6,239.0", "bbox": [680.0, 626.7, 820.0, 647.3]}, {"text": "$ 5,879.5 $", "bbox": [845.6, 626.7, 944.1, 647.3]}, {"text": "— $", "bbox": [1016.9, 626.7, 1056.4, 647.3]}, {"text": "5,879.5", "bbox": [1086.6, 626.7, 1145.0, 647.3]}, {"text": "CRITICAL ACCOUNTING ESTIMATES", "bbox": [88.6, 694.2, 490.8, 724.8]}, {"text": "We believe the following accounting estimates are the most critical", "bbox": [88.6, 742.1, 605.5, 763.2]}, {"text": "to the understanding of our financial statements as they could", "bbox": [88.6, 764.6, 605.4, 785.7]}, {"text": "have the most significant effect on our reported results and require", "bbox": [88.6, 787.1, 605.4, 808.2]}, {"text": "subjective or complex judgments by management. Accounting", "bbox": [88.6, 809.6, 606.3, 830.7]}, {"text": "principles generally accepted in the United States require us to", "bbox": [88.6, 832.1, 605.8, 853.2]}, {"text": "make estimates and assumptions that affect the reported amounts", "bbox": [88.6, 854.6, 605.6, 875.8]}, {"text": "of assets and liabilities at the date of the consolidated financial", "bbox": [88.6, 877.1, 605.4, 898.3]}, {"text": "statements and revenues and expenses during the periods", "bbox": [88.6, 899.6, 605.6, 920.8]}, {"text": "reported. These estimates are based on our best judgment about", "bbox": [88.6, 922.1, 605.9, 943.3]}, {"text": "current and future conditions, but actual results could differ from", "bbox": [88.6, 944.6, 605.9, 965.8]}, {"text": "those estimates. Refer to Note 1 in the Financial Statements for", "bbox": [88.6, 967.1, 605.7, 988.3]}, {"text": "information regarding our significant accounting policies.", "bbox": [88.6, 989.7, 543.2, 1010.8]}, {"text": "RETIREMENT BENEFITS — PENSION", "bbox": [88.6, 1036.9, 443.4, 1062.8]}, {"text": "Pension costs and obligations are actuarially determined and", "bbox": [88.6, 1075.1, 605.8, 1096.3]}, {"text": "are influenced by assumptions used to estimate these amounts,", "bbox": [88.6, 1097.6, 605.9, 1118.8]}, {"text": "including the discount rate and the expected rate of return on plan", "bbox": [88.6, 1120.1, 606.0, 1141.3]}, {"text": "assets. Changes in any of the assumptions and the amortization of", "bbox": [88.6, 1142.6, 606.3, 1163.8]}, {"text": "differences between the assumptions and actual experience will", "bbox": [88.6, 1165.1, 605.9, 1186.3]}, {"text": "affect the amount of pension expense in future periods.", "bbox": [88.6, 1187.7, 528.1, 1208.8]}, {"text": "Our global pension expense in 2018 was $114.1 million compared", "bbox": [88.6, 1222.0, 606.0, 1243.1]}, {"text": "to $175.9 million in 2017. Approximately 79 percent of our 2018", "bbox": [88.6, 1244.5, 605.9, 1265.6]}, {"text": "global pension expense relates to our U.S. pension plan. The", "bbox": [88.6, 1267.0, 606.0, 1288.1]}, {"text": "actuarial assumptions used to determine our 2018 U.S. pension", "bbox": [636.7, 742.1, 1153.8, 763.2]}, {"text": "expense included the following: discount rate of 3.90 percent", "bbox": [636.7, 764.6, 1154.1, 785.7]}, {"text": "(compared to 3.75 percent for 2017) and expected rate of return", "bbox": [636.7, 787.1, 1153.9, 808.2]}, {"text": "on plan assets of 7.50 percent (consistent with 2017).", "bbox": [636.7, 809.6, 1060.8, 830.7]}, {"text": "For 2019 our U.S. discount rate will increase to 4.35 percent", "bbox": [636.7, 843.9, 1154.3, 865.1]}, {"text": "from 3.90 percent in 2018. The discount rate was set as of", "bbox": [636.7, 866.4, 1153.8, 887.6]}, {"text": "our September 30 measurement date and was determined by", "bbox": [636.7, 888.9, 1153.9, 910.1]}, {"text": "modeling a portfolio of bonds that match the expected cash flow", "bbox": [636.7, 911.5, 1153.9, 932.6]}, {"text": "of our benefit plans.", "bbox": [636.7, 934.0, 795.7, 955.1]}, {"text": "For 2019 our expected rate of return on U.S. plan assets will remain", "bbox": [636.7, 968.3, 1153.6, 989.4]}, {"text": "7.50 percent. In estimating the expected return on plan assets,", "bbox": [636.7, 990.8, 1154.0, 1011.9]}, {"text": "we considered actual returns on plan assets over the long term,", "bbox": [636.7, 1013.3, 1154.0, 1034.4]}, {"text": "adjusted for forward-looking considerations, such as inflation,", "bbox": [636.7, 1035.8, 1154.3, 1056.9]}, {"text": "interest rates, equity performance and the active management", "bbox": [636.7, 1058.3, 1153.9, 1079.4]}, {"text": "of the plan’s invested assets. We also considered our current", "bbox": [636.7, 1080.8, 1153.9, 1102.0]}, {"text": "and expected mix of plan assets in setting this assumption. The", "bbox": [636.7, 1103.3, 1154.0, 1124.5]}, {"text": "financial markets produced positive returns in 2018. The plan’s", "bbox": [636.7, 1125.8, 1154.2, 1147.0]}, {"text": "debt securities return was positive. The plan’s equity securities", "bbox": [636.7, 1148.3, 1153.5, 1169.5]}, {"text": "return was above the expected return range in 2018, as U.S. and", "bbox": [636.7, 1170.8, 1154.0, 1192.0]}, {"text": "international equity returns were positive for the year. The actual", "bbox": [636.7, 1193.4, 1154.0, 1214.5]}, {"text": "return for our portfolio of U.S. plan assets was approximately", "bbox": [636.7, 1215.9, 1154.0, 1237.0]}, {"text": "7.88 percent annualized for the 15 years ended September 30,", "bbox": [636.7, 1238.4, 1154.0, 1259.5]}, {"text": "2018, and was approximately 7.46 percent annualized for the", "bbox": [636.7, 1260.9, 1153.6, 1282.0]}, {"text": "20 years ended September 30, 2018.", "bbox": [636.7, 1283.4, 928.7, 1304.5]}, {"text": "The target allocations and ranges of long-term expected return for our major categories of U.S. plan assets are as follows:", "bbox": [88.6, 1317.7, 1059.5, 1338.8]}, {"text": "Asset Category", "bbox": [94.5, 1379.6, 204.5, 1398.8]}, {"text": "Target", "bbox": [920.5, 1360.5, 969.8, 1379.2]}, {"text": "Allocations", "bbox": [887.2, 1380.0, 965.9, 1398.7]}, {"text": "Expected Return", "bbox": [1026.3, 1380.0, 1143.2, 1398.7]}, {"text": "Equity securities", "bbox": [94.5, 1408.6, 219.2, 1428.6]}, {"text": "55%", "bbox": [933.4, 1408.6, 965.9, 1428.6]}, {"text": "9%   –  10%", "bbox": [1038.9, 1408.6, 1143.2, 1428.6]}, {"text": "Debt securities", "bbox": [94.5, 1438.4, 207.3, 1458.4]}, {"text": "40%", "bbox": [933.4, 1438.4, 965.9, 1458.4]}, {"text": "4%   –    6%", "bbox": [1039.5, 1438.4, 1143.2, 1458.4]}, {"text": "Other", "bbox": [94.5, 1468.2, 136.3, 1488.2]}, {"text": "5%", "bbox": [942.9, 1468.2, 965.9, 1488.2]}, {"text": "6%   –  11%", "bbox": [1038.9, 1468.2, 1143.2, 1488.2]}]}