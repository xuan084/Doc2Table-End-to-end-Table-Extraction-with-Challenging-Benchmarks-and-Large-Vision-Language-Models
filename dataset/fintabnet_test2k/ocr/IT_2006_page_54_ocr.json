500.7]}, {"text": "entries is to adjust the amount of goodwill recorded on the META acquisition.", "bbox": [212.5, 1509.0, 832.2, 1527.8]}, {"text": "49", "bbox": [1079.2, 1559.5, 1100.0, 1578.2]}]}