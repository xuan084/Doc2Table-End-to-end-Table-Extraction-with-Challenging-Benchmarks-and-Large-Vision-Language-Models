bbox": [75.0, 947.7, 1157.8, 966.4]}, {"text": "the next three years are not expected to have a material adverse impact on Occidental.", "bbox": [75.0, 970.2, 797.6, 988.9]}, {"text": "Q", "bbox": [517.7, 9.3, 547.4, 47.3]}]}